{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "personalityProfile": {
          "type": "object",
          "description": "Detailed personality traits from assessments",
          "properties": {
            "mbti": { "type": "string" },
            "enneagram": { "type": "string" },
            "traits": { "type": "object" },
            "completedAt": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["alter-ego", "split-personality"] },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "config": { "type": "object" },
        "isSaved": { "type": "boolean" }
      },
      "required": ["userId", "type", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "agentType": { "type": "string" },
        "emotions": { "type": "object" },
        "confidenceMetrics": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "userId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Conversation sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    }
  }
}